{
	"schemaVersion": 1,
	"id": "veltium-mod",
	"version": "${version}",
	"name": "Veltium",
	"description": "Displays FPS, memory usage, ping, coordinates, real time, in-game time, and day counter — a best customizable HUD mod for Minecraft.",
	"authors": [
		"5120"
	],
	"contact": {
		"homepage": "https://modrinth.com/mod/veltium",
		"sources": "https://github.com/m5120/Veltium",
		"issues": "https://github.com/m5120/Veltium/issues"
	},
	"license": "CC0-1.0",
	"icon": "assets/template-mod/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.veltium.TemplateMod"
		],
		"client": [
			"com.veltium.Veltium"
		],
		"modmenu": [
			"com.veltium.OptimizationModMenuIntegration"
		],
		"sodium:config_api_user": ["com.veltium.config.VeltiumSodiumConfig"]
	},

	"mixins": [
		"veltium.mixins.json",
		{
			"config": "veltium.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.4",
		"minecraft": ">=26.1",
		"java": ">=25",
		"fabric-api": "*",
		"yet_another_config_lib_v3": "*"

	},
	"suggests": {
		"modmenu": "*",
		"sodium": ">=0.8.0"
	}
}